# ═══════════════════════════════════════════════════════════
# Spark Chicken Games — Variáveis de Ambiente
# ═══════════════════════════════════════════════════════════
# Copie e cole no Vercel → Project Settings → Environment Variables
# ═══════════════════════════════════════════════════════════
#
# ⚠️  São DOIS projetos no Vercel:
#     1. Frontend (Next.js) → Root Directory: frontend/
#     2. Backend (Go/Gin)   → Root Directory: backend/
#
# As variáveis abaixo estão organizadas por projeto.
# ═══════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────
# PROJETO 1: FRONTEND (Next.js)
# ──────────────────────────────────────────────────────────
# Vercel Project: spark-chicken-games
# Root Directory: frontend/
# Framework: Next.js
# ──────────────────────────────────────────────────────────

# URL da API (em produção, a URL do projeto backend no Vercel)
NEXT_PUBLIC_API_URL=https://spark-chicken-games-api.vercel.app/api/v1

# ──────────────────────────────────────────────────────────
# PROJETO 2: BACKEND (Go/Gin)
# ──────────────────────────────────────────────────────────
# Vercel Project: spark-chicken-games-api
# Root Directory: backend/
# Framework: Other (Go Serverless Function)
# ──────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────
SCG_APP_NAME=spark-chicken-games
SCG_APP_ENVIRONMENT=production
SCG_APP_DEBUG=false
SCG_APP_VERSION=1.0.0

# ── PostgreSQL (ou Vercel Postgres) ───────────────────────
SCG_DATABASE_HOST=<seu-host-postgres>
SCG_DATABASE_PORT=5432
SCG_DATABASE_USER=<seu-usuario>
SCG_DATABASE_PASSWORD=<sua-senha>
SCG_DATABASE_NAME=spark_chicken_games
SCG_DATABASE_SSLMODE=require
SCG_DATABASE_MAX_OPEN_CONNS=10
SCG_DATABASE_MAX_IDLE_CONNS=5
SCG_DATABASE_CONN_MAX_LIFETIME=5m
SCG_DATABASE_CONN_MAX_IDLE_TIME=2m

# ── Redis (ou Vercel KV) ──────────────────────────────────
SCG_REDIS_HOST=<seu-host-redis>
SCG_REDIS_PORT=6379
SCG_REDIS_PASSWORD=<sua-senha-redis>
SCG_REDIS_DB=0
SCG_REDIS_POOL_SIZE=10
SCG_REDIS_MIN_IDLE_CONNS=2

# ── JWT ───────────────────────────────────────────────────
SCG_JWT_ACCESS_SECRET=<acesso-secret-mude-isso>
SCG_JWT_REFRESH_SECRET=<refresh-secret-mude-isso>
SCG_JWT_ACCESS_TOKEN_EXPIRY=15m
SCG_JWT_REFRESH_TOKEN_EXPIRY=168h
SCG_JWT_ISSUER=spark-chicken-games

# ── CORS (adicione a URL do frontend) ─────────────────────
SCG_CORS_ALLOWED_ORIGINS=https://spark-chicken-games.vercel.app
SCG_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
SCG_CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-Requested-With
SCG_CORS_EXPOSED_HEADERS=Content-Length
SCG_CORS_ALLOW_CREDENTIALS=true
SCG_CORS_MAX_AGE=86400

# ── Rate Limit ────────────────────────────────────────────
SCG_RATELIMIT_ENABLED=true
SCG_RATELIMIT_REQUESTS_PER_MINUTE=60
SCG_RATELIMIT_BURST=10
